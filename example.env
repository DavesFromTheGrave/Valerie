# Example configuration for Grave-Lorelai (public Lorelai product scaffolding)
# Copy this file to .env (or set as environment variables) and fill in your real values locally ONLY.
# NEVER commit a real .env file. This example is safe for the public repo.

# Ollama (local LLM for text/spoken content)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=revenant/nsfw-v-8b:latest

# Future cloud TTS (e.g. Google or Grok Ara) - fill only for personal testing
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/service-account.json
# GROK_TTS_API_KEY=your-key-here   # if/when available

# ComfyUI (local images - will run after audio)
COMFYUI_URL=http://127.0.0.1:8188

# Any other non-sensitive example values
# LOG_LEVEL=Information
