{
  "_comment": "Standard txt2img workflow. C# code mutates nodes 1/3/4/5/6 at runtime (checkpoint, resolution, positive, negative, seed). Export a fresh one from ComfyUI API format if you swap the pipeline.",
  "1": {
    "inputs": { "ckpt_name": "cyberrealisticPony_v180Coreshift.safetensors" },
    "class_type": "CheckpointLoaderSimple"
  },
  "4": {
    "inputs": { "text": "", "clip": ["1", 1] },
    "class_type": "CLIPTextEncode"
  },
  "5": {
    "inputs": { "text": "", "clip": ["1", 1] },
    "class_type": "CLIPTextEncode"
  },
  "3": {
    "inputs": { "width": 512, "height": 768, "batch_size": 1 },
    "class_type": "EmptyLatentImage"
  },
  "6": {
    "inputs": {
      "seed": 0,
      "steps": 20,
      "cfg": 4,
      "sampler_name": "euler",
      "scheduler": "normal",
      "denoise": 1,
      "model": ["1", 0],
      "positive": ["4", 0],
      "negative": ["5", 0],
      "latent_image": ["3", 0]
    },
    "class_type": "KSampler"
  },
  "7": {
    "inputs": { "samples": ["6", 0], "vae": ["1", 2] },
    "class_type": "VAEDecode"
  },
  "8": {
    "inputs": { "filename_prefix": "Valerie", "images": ["7", 0] },
    "class_type": "SaveImage"
  }
}
