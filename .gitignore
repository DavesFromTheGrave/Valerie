# Build output
bin/
obj/

# Secrets — DPAPI-encrypted key store (never committed)
secrets/
*.key

# V's persona is private — it lives in the immutable M:\V-Prompts vault, never in the repo.
# The live system prompt (copied out of the vault) and any modelfiles that embed it stay local.
Config/system_prompt.txt
modelfiles/

# Local config overrides (non-secret) / misc
appsettings.Local.json
.env
*.user

# Generated selfies (keep the folder, ignore the images)
selfies/*
!selfies/.gitkeep

# OS cruft
Thumbs.db
.DS_Store
Config/username.txt
