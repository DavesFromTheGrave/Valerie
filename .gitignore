# Build output
bin/
obj/

# Secrets — DPAPI-encrypted key store (never committed)
secrets/
*.key

# V's persona is private — it lives in the immutable M:\V-Prompts vault, never in the repo.
# The live system prompt (copied out of the vault) and any modelfiles that embed it stay local.
Config/system_prompt.txt
modelfiles/

# Local config overrides (non-secret) / misc
appsettings.Local.json
.env
*.user
*.log

# Generated selfies (keep the folder, ignore the images)
selfies/*
!selfies/.gitkeep

# OS cruft
Thumbs.db
.DS_Store
Config/username.txt

#Documentation
docs/

# Local TTS (F5-TTS): virtualenv, model cache, dataset, checkpoints, samples — all generated/huge.
# This is the 250k+ untracked files: .venv alone is ~54k, dataset is 11k WAVs.
local-tts/.venv/
local-tts/.cache/
local-tts/dataset/
local-tts/samples/
local-tts/ckpts/
# trained voice checkpoints (3.2 GB each) — kept on disk, never in git
local-tts/keepers/

# V's voice-clone material (derived from the private raw clips) stays out of git, like the persona.
local-tts/ref/
voice_ref*
voice_raw*

# memory cache for the TTS model (generated, huge)
v-Memory/*
superm0d/